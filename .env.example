# Budabit Environment Configuration

# Platform Configuration
VITE_PLATFORM_NAME=Budabit
VITE_PLATFORM_ACCENT=#8B5CF6
VITE_PLATFORM_DESCRIPTION=Social Git collaboration on Nostr
# Optional explicit allowlist for room/channel creation on platform relays.
# Comma-separated hex pubkeys or npubs. When set, only these pubkeys can create rooms.
# When unset, room creation falls back to relay owner pubkey checks.
VITE_PLATFORM_ROOM_CREATOR_PUBKEYS=

# Notifier (Anchor)
# These are required for email alerts; handler values are optional overrides.
# VITE_NOTIFIER_HANDLER_ADDRESS should be a handler address (kind:pubkey:identifier).
# VITE_NOTIFIER_HANDLER_RELAY should be the relay hosting the handler event.
VITE_NOTIFIER_RELAY=
VITE_NOTIFIER_PUBKEY=
VITE_NOTIFIER_HANDLER_ADDRESS=
VITE_NOTIFIER_HANDLER_RELAY=

# Build Environment
NODE_ENV=development

# ====================================================================
# FEATURE FLAGS (Build-time Constants)
# ====================================================================
# These flags control which features are compiled into the application.
# When set to "0", the associated code is completely removed from the
# final bundle via tree-shaking, reducing bundle size.
#
# Default behavior (when not set):
# - FEATURE_GRASP: enabled (included in build)
# - FEATURE_TERMINAL: enabled (included in build)
# - FEATURE_NIP34_PR: disabled (excluded from build)
# - FEATURE_CICD: disabled (excluded from build)
# - FEATURE_STRICT_NIP29: disabled (excluded from build)
# ====================================================================

# GRASP Git Protocol Integration
# Enables GRASP relay support for Git repository state synchronization
# Set to "0" to disable and remove ~50KB from bundle
FEATURE_GRASP=1

# Terminal UI Components
# Enables terminal emulator components for Git CLI operations
# Set to "0" to disable and remove ~150KB from bundle
FEATURE_TERMINAL=1

# NIP-34 Pull Request Format
# Enables updated NIP-34 Pull Request event format support
# Set to "1" to enable experimental PR format features
FEATURE_NIP34_PR=0

# CI/CD Automation Features
# Enables GitHub Actions integration and automation workflows
# Set to "1" to enable CI/CD features
FEATURE_CICD=0

# Strict NIP-29 Validation
# Enables strict validation for NIP-29 group/room federation
# Set to "1" to enforce stricter conversation thread validation
FEATURE_STRICT_NIP29=0

# ====================================================================
# Nostr Configuration
# ====================================================================

# Default Nostr Relays (semicolon-separated)
NOSTR_DEFAULT_RELAYS=wss://relay.damus.io;wss://nos.lol

# Fallback Relays
NOSTR_FALLBACK_RELAYS=wss://purplerelay.com;wss://purplepages.es;wss://relayable.org

# GRASP Relays (only used when FEATURE_GRASP=1)
NOSTR_GRASP_RELAYS=wss://relay.ngit.dev;wss://gitnostr.com

# GRASP Integration Toggle (runtime, requires FEATURE_GRASP=1)
NOSTR_ENABLE_GRASP=true

# Repository State Publishing
NOSTR_PUBLISH_REPO_STATE=true
NOSTR_PUBLISH_REPO_ANNOUNCEMENTS=false

# ====================================================================
# Git Configuration
# ====================================================================

# App-level default CORS proxy for git HTTP operations
# Users can still override this at runtime from Settings > Profile.
VITE_GIT_DEFAULT_CORS_PROXY=https://corsproxy.budabit.club

# Optional package-level fallback used in non-app contexts.
# Set to "none" to disable proxy when that fallback is used.
GIT_DEFAULT_CORS_PROXY=https://cors.isomorphic-git.org

# ====================================================================
# Development/Debug
# ====================================================================

# Show debug logging in extension
NOSTR_GIT_SHOW_DEBUG=true

# Comma-separated hostnames allowed by Vite dev server.
# Useful when proxying local dev through a VPS domain.
# Example: VITE_DEV_ALLOWED_HOSTS=budabit-dev.example.com
VITE_DEV_ALLOWED_HOSTS=

# Optional HMR overrides when running dev server behind reverse proxy.
# Typical HTTPS proxy setup:
# VITE_DEV_HMR_PROTOCOL=wss
# VITE_DEV_HMR_HOST=budabit-dev.example.com
# VITE_DEV_HMR_CLIENT_PORT=443
VITE_DEV_HMR_PROTOCOL=
VITE_DEV_HMR_HOST=
VITE_DEV_HMR_PORT=
VITE_DEV_HMR_CLIENT_PORT=
VITE_DEV_HMR_PATH=

# Optional Chii target script URL for mobile remote debugging.
# Enable via ?chii=1 on the dev URL and disable with ?chii=0.
# Example: VITE_DEV_CHII_TARGET_URL=https://budabit-debug.example.com/target.js
VITE_DEV_CHII_TARGET_URL=
