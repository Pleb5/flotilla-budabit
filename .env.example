# Budabit Environment Configuration

# ====================================================================
# Fallback App Identity And Branding
# ====================================================================

# Runtime app identity is loaded from VITE_DEFAULT_COMMUNITY's Nostr profile
# whenever a default/selected community is available. These values are fallback
# deployment metadata for first paint, PWA generation, and missing community fields.
VITE_PLATFORM_NAME=Budabit
VITE_PLATFORM_DESCRIPTION=Social Git collaboration on Nostr
VITE_PLATFORM_ACCENT=#8B5CF6
VITE_PLATFORM_ACCENT_CONTENT=#EAE7FF

# Fallback URL/logo. Community profile website/picture override these at runtime
# for app UI and NIP-46 metadata. PWA assets are still generated at build time
# from VITE_PLATFORM_LOGO.
VITE_PLATFORM_URL=http://localhost:1847
VITE_PLATFORM_LOGO=http://localhost:1847/logo.png
VITE_PLATFORM_TERMS=
VITE_PLATFORM_PRIVACY=
VITE_PLATFORM_SECONDARY=
VITE_PLATFORM_SECONDARY_CONTENT=#EAE7FF

# ====================================================================
# Community And Relay Discovery
# ====================================================================

# Default Communikey community shown in the app shell and home selector.
# Accepts a hex pubkey, npub, or ncommunity URI. Relay hints in ncommunity
# are used first; VITE_INDEXER_RELAYS are the fallback discovery relays.
VITE_DEFAULT_COMMUNITY=

# General Nostr indexer/discovery relays. Also used as fallback relays for
# resolving the default community definition before its own relays are known.
VITE_INDEXER_RELAYS=wss://purplepag.es/,wss://relay.damus.io/

# NIP-46 signer discovery relays.
VITE_SIGNER_RELAYS=wss://relay.damus.io,wss://nos.lol

# Pubkeys used to bootstrap the local trust graph.
VITE_DEFAULT_PUBKEYS=

# Default Blossom media servers for uploads.
VITE_DEFAULT_BLOSSOM_SERVERS=

# Optional widget discovery relays. If empty, app defaults are used.
VITE_SMART_WIDGET_RELAYS=

# ====================================================================
# Git
# ====================================================================

# Relays used for Nostr Git repository discovery and Git-related events.
VITE_GIT_RELAYS=wss://relay.ngit.dev,wss://gitnostr.com

# App-level default CORS proxy for git HTTP operations. Users can override
# this at runtime from Settings > Profile.
VITE_GIT_DEFAULT_CORS_PROXY=https://corsproxy.budabit.club

# ====================================================================
# Optional Services
# ====================================================================

# Optional hosted email/password account service. Leave empty to hide those flows.
VITE_BURROW_URL=

# Notifier/Anchor. Required only for email or push alerts.
# Handler values are optional overrides.
VITE_NOTIFIER_RELAY=
VITE_NOTIFIER_PUBKEY=
VITE_NOTIFIER_HANDLER_ADDRESS=
VITE_NOTIFIER_HANDLER_RELAY=
VITE_VAPID_PUBLIC_KEY=

# Build hash shown in Settings > About and used by the service worker.
# Usually injected by CI; safe to leave empty locally.
VITE_BUILD_HASH=

# ====================================================================
# Build Environment
# ====================================================================

NODE_ENV=development

# ====================================================================
# FEATURE FLAGS (Build-time Constants)
# ====================================================================
# These flags control which features are compiled into the application.
# When set to "0", the associated code is removed from the final bundle
# via tree-shaking where possible.
#
# Default behavior when not set:
# - FEATURE_GRASP: enabled
# - FEATURE_TERMINAL: enabled
# - FEATURE_NIP34_PR: disabled
# - FEATURE_CICD: disabled
# - FEATURE_STRICT_NIP29: disabled
# ====================================================================

FEATURE_GRASP=1
FEATURE_TERMINAL=1
FEATURE_NIP34_PR=0
FEATURE_CICD=0
FEATURE_STRICT_NIP29=0

# ====================================================================
# Package-only Nostr Git Configuration
# ====================================================================
# These variables are not read by the Budabit app shell directly. They only
# affect package/library entry points under packages/ when those packages are
# run directly in Node or separate package builds.

# Default package-level Nostr Git provider relays. Semicolon-separated.
NOSTR_DEFAULT_RELAYS=wss://relay.damus.io;wss://nos.lol

# Package-level fallback relays used by @nostr-git/core provider factories.
NOSTR_FALLBACK_RELAYS=wss://purplerelay.com;wss://purplepages.es;wss://relayable.org

# Package-level GRASP relay defaults and runtime toggle.
NOSTR_GRASP_RELAYS=wss://relay.ngit.dev;wss://gitnostr.com
NOSTR_ENABLE_GRASP=true

# Package-level toggles for publishing repository state/announcements.
NOSTR_PUBLISH_REPO_STATE=true
NOSTR_PUBLISH_REPO_ANNOUNCEMENTS=false

# Package-level fallback CORS proxy used by @nostr-git/core outside the app.
# The Budabit app uses VITE_GIT_DEFAULT_CORS_PROXY instead.
GIT_DEFAULT_CORS_PROXY=https://cors.isomorphic-git.org

# Package/release-build debug hint for extension builds.
NOSTR_GIT_SHOW_DEBUG=true

# ====================================================================
# Development/Debug
# ====================================================================

# Comma-separated hostnames allowed by Vite dev server.
# Useful when proxying local dev through a VPS domain.
# Example: VITE_DEV_ALLOWED_HOSTS=budabit-dev.example.com
VITE_DEV_ALLOWED_HOSTS=

# Optional HMR overrides when running dev server behind reverse proxy.
# Set VITE_DEV_HMR_ENABLED=1 to apply the override values.
# Typical HTTPS proxy setup:
# VITE_DEV_HMR_ENABLED=1
# VITE_DEV_HMR_PROTOCOL=wss
# VITE_DEV_HMR_HOST=budabit-dev.example.com
# VITE_DEV_HMR_CLIENT_PORT=443
VITE_DEV_HMR_ENABLED=
VITE_DEV_HMR_PROTOCOL=
VITE_DEV_HMR_HOST=
VITE_DEV_HMR_PORT=
VITE_DEV_HMR_CLIENT_PORT=
VITE_DEV_HMR_PATH=

# Optional Chii target script URL for mobile remote debugging.
# Enable via ?chii=1 on the dev URL and disable with ?chii=0.
# Example: VITE_DEV_CHII_TARGET_URL=https://budabit-debug.example.com/target.js
VITE_DEV_CHII_TARGET_URL=
