<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteRule ^404\.html$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # for Test deploy use this rule:
    RewriteRule . /index.html [L]
    # RewriteRule . /404.html [L]
</IfModule>

<IfModule mod_headers.c>
    SetEnvIfNoCase Request_URI "^/\.well-known/" budabit_well_known=1
    SetEnvIfNoCase Request_URI "^/_app/immutable/" budabit_immutable_asset=1

    Header unset Cache-Control
    Header unset Pragma
    Header unset Expires

    Header always set Access-Control-Allow-Origin "*" env=budabit_well_known
    Header always set Access-Control-Allow-Headers "*" env=budabit_well_known
    Header always set Access-Control-Allow-Methods "GET" env=budabit_well_known

    # Default all mutable assets and SPA shell responses to revalidate.
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set Expires "0"

    # Only hashed build artifacts should be cached forever.
    Header always set Cache-Control "public, max-age=31536000, immutable" env=budabit_immutable_asset
    Header always unset Pragma env=budabit_immutable_asset
    Header always unset Expires env=budabit_immutable_asset
</IfModule>

AddType application/manifest+json .webmanifest
AddType application/json .json
