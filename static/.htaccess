<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteRule ^404\.html$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # for Test deploy use this rule:
    RewriteRule . /index.html [L]
    # RewriteRule . /404.html [L]
</IfModule>

<If "%{REQUEST_URI} =~ m#^/.well-known/#">
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Headers "*" 
    Header always set Access-Control-Allow-Methods "GET" 
</If> 

<IfModule mod_headers.c>
    Header unset Cache-Control
    Header unset Pragma
    Header unset Expires

    # Default all mutable assets and SPA shell responses to revalidate.
    Header always set Cache-Control "no-cache, no-store, must-revalidate"
    Header always set Pragma "no-cache"
    Header always set Expires "0"

    # Only hashed build artifacts should be cached forever.
    <If "%{REQUEST_URI} =~ m#^/_app/immutable/#">
        Header always unset Cache-Control
        Header always unset Pragma
        Header always unset Expires
        Header always set Cache-Control "public, max-age=31536000, immutable"
    </If>

    # These endpoints drive update detection and should never be pinned.
    <If "%{REQUEST_URI} =~ m#^/(service-worker\.js|manifest\.webmanifest|_app/version\.json)$#">
        Header always set Cache-Control "no-cache, no-store, must-revalidate"
        Header always set Pragma "no-cache"
        Header always set Expires "0"
    </If>
</IfModule>

AddType application/manifest+json .webmanifest .json
